{
  "name": "agw-vscode",
  "displayName": "agentgateway",
  "description": "AI chat and MCP tool browser for agentgateway",
  "version": "0.3.1",
  "publisher": "sebastianmaniak",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastianmaniak/agw-vscode-extension"
  },
  "icon": "resources/agw-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agw-explorer",
          "title": "agentgateway",
          "icon": "resources/agw-icon.svg"
        }
      ]
    },
    "views": {
      "agw-explorer": [
        {
          "id": "agw-tools",
          "name": "MCP Tools"
        },
        {
          "type": "webview",
          "id": "agw-chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "agw.openChat",
        "title": "Open Chat",
        "category": "agentgateway",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agw.refreshTools",
        "title": "Refresh Tools",
        "category": "agentgateway",
        "icon": "$(refresh)"
      },
      {
        "command": "agw.configure",
        "title": "Configure",
        "category": "agentgateway",
        "icon": "$(gear)"
      },
      {
        "command": "agw.sendToChat",
        "title": "Send Selection to Chat",
        "category": "agentgateway",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agw.toggleTool",
        "title": "Toggle Tool for Chat",
        "category": "agentgateway"
      },
      {
        "command": "agw.inspectTool",
        "title": "Inspect Tool",
        "category": "agentgateway"
      }
    ],
    "keybindings": [
      {
        "command": "agw.sendToChat",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "agw.sendToChat",
          "group": "agw",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "agw.refreshTools",
          "when": "view == agw-tools",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agw.toggleTool",
          "when": "view == agw-tools"
        },
        {
          "command": "agw.inspectTool",
          "when": "view == agw-tools"
        }
      ]
    },
    "configuration": {
      "title": "agentgateway",
      "properties": {
        "agw.llmEndpoint": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the agentgateway LLM listener (OpenAI-compatible API)"
        },
        "agw.mcpEndpoint": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the agentgateway MCP listener"
        },
        "agw.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticated agentgateway instances"
        },
        "agw.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default LLM model to use for chat (leave empty to type any model name)"
        },
        "agw.modelPresets": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Model identifier (e.g., gpt-4o)"
              },
              "provider": {
                "type": "string",
                "description": "Provider name (e.g., OpenAI, Anthropic)"
              }
            },
            "required": [
              "id"
            ]
          },
          "description": "Preset model list with optional provider labels for quick switching"
        },
        "agw.gateways": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this gateway (e.g., Production, Staging)"
              },
              "llmEndpoint": {
                "type": "string",
                "description": "URL of the LLM listener"
              },
              "mcpEndpoint": {
                "type": "string",
                "description": "URL of the MCP listener"
              },
              "apiKey": {
                "type": "string",
                "description": "API key for this gateway"
              },
              "defaultModel": {
                "type": "string",
                "description": "Default model for this gateway"
              }
            },
            "required": [
              "name",
              "llmEndpoint",
              "mcpEndpoint"
            ]
          },
          "description": "Multiple agentgateway instances to switch between (each with their own LLM and MCP endpoints)"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "check-types": "tsc --noEmit && tsc --noEmit -p src/webview/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:patch": "npm version patch -m 'release: v%s' && git push --follow-tags",
    "release:minor": "npm version minor -m 'release: v%s' && git push --follow-tags",
    "release:major": "npm version major -m 'release: v%s' && git push --follow-tags"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "preact": "^10.24.0",
    "htm": "^3.1.1",
    "marked": "^14.0.0",
    "highlight.js": "^11.10.0",
    "dompurify": "^3.1.0",
    "@types/dompurify": "^3.0.5"
  },
  "dependencies": {
    "preact": "^10.24.0",
    "htm": "^3.1.1",
    "marked": "^14.0.0",
    "highlight.js": "^11.10.0",
    "dompurify": "^3.1.0"
  }
}
